# Copy to .env (gitignored) and fill in. Never commit real secrets.

# Postgres connection. Local docker-compose / cluster default:
DATABASE_URL=postgresql://revenue:revenue@localhost:5432/hotel_revenue

# Model API key. The agent is provider-agnostic (MODEL_ID picks the provider); set the
# key for whichever you use, e.g. ANTHROPIC_API_KEY for Claude or GROQ_API_KEY for Groq.
ANTHROPIC_API_KEY=sk-ant-...

# Model id (provider:model). Swappable via langchain init_chat_model; Claude by default.
# Examples: anthropic:claude-sonnet-4-6, groq:llama-3.3-70b-versatile, openai:gpt-4o.
MODEL_ID=anthropic:claude-sonnet-4-6

# HTTP basic auth for the chat UI. Change these before exposing the app on a network.
BASIC_AUTH_USER=admin
BASIC_AUTH_PASS=change-me

# Tool transport: "direct" (in-process, the default, used by tests and local runs) or
# "mcp" (the agent loads the five tools from the MCP server).
RM_TOOL_TRANSPORT=direct

# MCP server URL, only when RM_TOOL_TRANSPORT=mcp and the server runs over streamable-http.
# Unset, the agent falls back to a local stdio subprocess.
MCP_SERVER_URL=http://127.0.0.1:9000/mcp
